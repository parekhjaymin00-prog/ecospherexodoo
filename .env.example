# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma format)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecosphere?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens — use a long, random string in prod
JWT_SECRET="change-me-to-a-long-random-string"

# ─── Mock Data Layer ─────────────────────────────────────────────────────────
# Set to "true" to use the built-in mock data layer instead of live DB queries.
# Required when other EcoSphere modules (Environmental, Social, Governance,
# Gamification) have not been built yet.
USE_MOCK_DATA="true"

# ─── File Storage ─────────────────────────────────────────────────────────────
# "local"  → store files on local disk under ./uploads/ (development)
# "minio"  → store files in MinIO / S3-compatible object storage (production)
STORAGE_DRIVER="local"

# MinIO / S3 credentials (required when STORAGE_DRIVER=minio)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="ecosphere-reports"

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
# Run locally with: docker run -p 6379:6379 redis:alpine
REDIS_URL="redis://localhost:6379"

# ─── Express Server ───────────────────────────────────────────────────────────
PORT="3001"

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Base URL that the browser uses to call backend API routes.
# Must match the backend PORT above. Vite dev-server proxy uses this as well.
VITE_API_BASE_URL="http://localhost:3001"
